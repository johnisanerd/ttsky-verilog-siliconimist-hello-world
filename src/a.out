:vpi_module "/usr/local/Cellar/icarus-verilog/13.0/lib/ivl/va_math.vpi";
S_0x7f97e50042d0 .scope module, "main" "main" 2 3;
 .timescale 0 0;
    .scope S_0x7f97e50042d0;
T_0 ;
    %vpi_call 2 7 "$display", "Hello World" {0 0 0};
    %vpi_call 2 8 "$finish" {0 0 0};
    %end;
    .thread T_0;
# The file index is used to find the file name in the following table.
:file_names 3;
